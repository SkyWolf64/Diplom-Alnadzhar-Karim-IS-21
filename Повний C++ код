// Множення в полі Галуа GF(2^8): xtime(x) = x*2 mod x^8+x^4+x^3+x+1
inline uint8_t xtime(uint8_t x) {
    return (x & 0x80) ? ((x << 1) ^ 0x1b) : (x << 1);
}

class AES128_Engine {
public:
    // ── Розширення ключа (Key Expansion), FIPS 197 §5.2 ──
    void keyExpansion(const uint8_t* key, uint8_t w[11][16]) {
        for (int i = 0; i < 16; i++) w[0][i] = key[i];
        for (int r = 1; r <= 10; r++) {
            uint8_t temp[4] = {
                w[r-1][12], w[r-1][13], w[r-1][14], w[r-1][15]
            };
            // RotWord
            uint8_t t0 = temp[0];
            temp[0] = temp[1]; temp[1] = temp[2];
            temp[2] = temp[3]; temp[3] = t0;
            // SubWord
            for (int i = 0; i < 4; i++) temp[i] = AES_SBOX[temp[i]];
            // XOR з RCON
            temp[0] ^= AES_RCON[r-1];
            // Перше слово раундового ключа
            for (int i = 0; i < 4; i++) w[r][i]   = w[r-1][i]   ^ temp[i];
            for (int i = 0; i < 4; i++) w[r][4+i] = w[r-1][4+i] ^ w[r][i];
            for (int i = 0; i < 4; i++) w[r][8+i] = w[r-1][8+i] ^ w[r][4+i];
            for (int i = 0; i < 4; i++) w[r][12+i]= w[r-1][12+i]^ w[r][8+i];
        }
    }

    // ── SubBytes: нелінійна підстановка через S-box (FIPS 197 §5.1.1) ──
    void subBytes(uint8_t* s) {
        for (int i = 0; i < 16; i++) s[i] = AES_SBOX[s[i]];
    }

    // ── ShiftRows: циклічний зсув рядків матриці стану (FIPS 197 §5.1.2) ──
    // Рядок 0: без зсуву | Рядок 1: зсув вліво на 1
    // Рядок 2: зсув вліво на 2 | Рядок 3: зсув вліво на 3
    void shiftRows(uint8_t* s) {
        uint8_t t;
        // Рядок 1 (байти 1,5,9,13): зсув на 1
        t=s[1]; s[1]=s[5]; s[5]=s[9]; s[9]=s[13]; s[13]=t;
        // Рядок 2 (байти 2,6,10,14): зсув на 2
        t=s[2]; s[2]=s[10]; s[10]=t;
        t=s[6]; s[6]=s[14]; s[14]=t;
        // Рядок 3 (байти 3,7,11,15): зсув на 3 (=зсув вправо на 1)
        t=s[15]; s[15]=s[11]; s[11]=s[7]; s[7]=s[3]; s[3]=t;
    }

    // ── MixColumns: лінійне перемішування стовпців GF(2^8) (FIPS 197 §5.1.3) ──
    void mixColumns(uint8_t* s) {
        for (int c = 0; c < 4; c++) {
            uint8_t s0=s[c*4], s1=s[c*4+1], s2=s[c*4+2], s3=s[c*4+3];
            s[c*4]   = xtime(s0)^xtime(s1)^s1^s2^s3;
            s[c*4+1] = s0^xtime(s1)^xtime(s2)^s2^s3;
            s[c*4+2] = s0^s1^xtime(s2)^xtime(s3)^s3;
            s[c*4+3] = xtime(s0)^s0^s1^s2^xtime(s3);
        }
    }

    // ── AddRoundKey: XOR стану з раундовим ключем (FIPS 197 §5.1.4) ──
    void addRoundKey(uint8_t* s, const uint8_t* rk) {
        for (int i = 0; i < 16; i++) s[i] ^= rk[i];
    }

    // ── InvSubBytes: зворотна підстановка через AES_INV_SBOX (FIPS 197 §5.3.2) ──
    void invSubBytes(uint8_t* s) {
        for (int i = 0; i < 16; i++) s[i] = AES_INV_SBOX[s[i]];
    }

    // ── InvShiftRows: циклічний зсув рядків матриці ВПРАВО (FIPS 197 §5.3.1) ──
    void invShiftRows(uint8_t* s) {
        uint8_t t;
        // Рядок 1: зсув вправо на 1
        t=s[13]; s[13]=s[9]; s[9]=s[5]; s[5]=s[1]; s[1]=t;
        // Рядок 2: зсув вправо на 2
        t=s[2]; s[2]=s[10]; s[10]=t; t=s[6]; s[6]=s[14]; s[14]=t;
        // Рядок 3: зсув вправо на 3 (=вліво на 1)
        t=s[3]; s[3]=s[7]; s[7]=s[11]; s[11]=s[15]; s[15]=t;
    }

    // Допоміжні множення GF(2^8) для InvMixColumns
    inline uint8_t gmul9 (uint8_t x) { return xtime(xtime(xtime(x))) ^ x; }
    inline uint8_t gmul11(uint8_t x) { return xtime(xtime(xtime(x))) ^ xtime(x) ^ x; }
    inline uint8_t gmul13(uint8_t x) { return xtime(xtime(xtime(x))) ^ xtime(xtime(x)) ^ x; }
    inline uint8_t gmul14(uint8_t x) { return xtime(xtime(xtime(x))) ^ xtime(xtime(x)) ^ xtime(x); }

    // ── InvMixColumns: лінійне перемішування стовпців GF(2^8) (FIPS 197 §5.3.3) ──
    // Матриця: {0e,0b,0d,09}, {09,0e,0b,0d}, {0d,09,0e,0b}, {0b,0d,09,0e}
    void invMixColumns(uint8_t* s) {
        for (int c = 0; c < 4; c++) {
            uint8_t s0=s[c*4], s1=s[c*4+1], s2=s[c*4+2], s3=s[c*4+3];
            s[c*4]   = gmul14(s0) ^ gmul11(s1) ^ gmul13(s2) ^ gmul9 (s3);
            s[c*4+1] = gmul9 (s0) ^ gmul14(s1) ^ gmul11(s2) ^ gmul13(s3);
            s[c*4+2] = gmul13(s0) ^ gmul9 (s1) ^ gmul14(s2) ^ gmul11(s3);
            s[c*4+3] = gmul11(s0) ^ gmul13(s1) ^ gmul9 (s2) ^ gmul14(s3);
        }
    }

    // ── Повне дешифрування одного 128-бітного блоку (FIPS 197 §5.3) ──
    // Початковий раунд: AddRoundKey (з w[10])
    // Раунди 1-9: InvShiftRows → InvSubBytes → AddRoundKey → InvMixColumns
    // Раунд 10 (фінальний): InvShiftRows → InvSubBytes → AddRoundKey (без InvMixColumns)
    void decrypt_block(uint8_t* block, const uint8_t* key) {
        uint8_t w[11][16];
        keyExpansion(key, w);
        addRoundKey(block, w[10]);
        for (int r = 9; r >= 1; r--) {
            invShiftRows(block);
            invSubBytes(block);
            addRoundKey(block, w[r]);
            invMixColumns(block);
        }
        // Фінальний раунд — без InvMixColumns
        invShiftRows(block);
        invSubBytes(block);
        addRoundKey(block, w[0]);
    }

    // ── Повне шифрування одного 128-бітного блоку (FIPS 197 §5.1) ──
    // Початковий раунд: AddRoundKey
    // Раунди 1-9: SubBytes → ShiftRows → MixColumns → AddRoundKey
    // Раунд 10 (фінальний): SubBytes → ShiftRows → AddRoundKey (без MixColumns)
    void encrypt_block(uint8_t* block, const uint8_t* key) {
        uint8_t w[11][16];
        keyExpansion(key, w);
        addRoundKey(block, w[0]);
        for (int r = 1; r <= 9; r++) {
            subBytes(block);
            shiftRows(block);
            mixColumns(block);
            addRoundKey(block, w[r]);
        }
        // Фінальний раунд — без MixColumns
        subBytes(block);
        shiftRows(block);
        addRoundKey(block, w[10]);
    }
};

// Шифрування потоку даних блоками 128 біт (ECB mode)
vector<uint8_t> aes128Encrypt(const vector<uint8_t>& data,
                               const vector<uint8_t>& key) {
    AES128_Engine aes;
    vector<uint8_t> result(data.begin(), data.end());
    for (size_t i = 0; i + 15 < result.size(); i += 16)
        aes.encrypt_block(&result[i], key.data());
    return result;
}

// Псевдонім для зворотної сумісності
inline vector<uint8_t> aesCipherExt(const vector<uint8_t>& d,
                                     const vector<uint8_t>& k) {
    return aes128Encrypt(d, k);
}


// Дешифрування потоку даних блоками 128 біт (ECB mode)
vector<uint8_t> aes128Decrypt(const vector<uint8_t>& cipherData,
                               const vector<uint8_t>& key) {
    AES128_Engine aes;
    vector<uint8_t> result(cipherData.begin(), cipherData.end());
    for (size_t i = 0; i + 15 < result.size(); i += 16)
        aes.decrypt_block(&result[i], key.data());
    return result;
}
// ─── 3. ГЕНЕТИЧНИЙ АЛГОРИТМ ──────────────────────────────────────
// ГА оптимізує 128-бітний ключ AES-128. Кожна особина — кандидат на ключ.
// Фітнес визначається статистичною якістю шифротексту (ентропія + P-value).

struct Individual {
    vector<uint8_t> key;   // Хромосома: 128-бітний AES-ключ (16 байт)
    double fitness;        // Значення фітнес-функції
};

// Фітнес-функція: F(X) = w1 * H_norm + w2 * P_value
// Шифруємо дані AES-128, оцінюємо якість шифрування статистично
double fitnessFunction(const vector<uint8_t>& d,
                       const vector<uint8_t>& k,
                       double w1, double w2) {
    auto enc  = aesCipherExt(d, k);
    auto freq = byteFrequency(enc);
    int  n    = (int)enc.size();
    double H  = calcEntropy(freq, n);
    double P  = pValueFromChi2(chiSquared(freq, n));
    return w1 * H + w2 * P;
}

// Ініціалізація популяції рівномірно випадковими ключами
vector<Individual> initPopulation(int sz, int klen,
    const vector<uint8_t>& d, double w1, double w2, mt19937& rng) {
    uniform_int_distribution<int> rb(0, 255);
    vector<Individual> pop(sz);
    for (auto& ind : pop) {
        ind.key.resize(klen);
        for (auto& b : ind.key) b = (uint8_t)rb(rng);
        ind.fitness = fitnessFunction(d, ind.key, w1, w2);
    }
    return pop;
}

// Турнірна селекція (розмір турніру k)
Individual tournamentSelect(const vector<Individual>& pop,
                             int k, mt19937& rng) {
    uniform_int_distribution<int> idx(0, (int)pop.size()-1);
    Individual best = pop[idx(rng)];
    for (int i = 1; i < k; i++) {
        const auto& cand = pop[idx(rng)];
        if (cand.fitness > best.fitness) best = cand;
    }
    return best;
}

// 3.2.2. Гібридний кросинговер: 70% двоточковий, 30% одноточковий
pair<Individual,Individual> hybridCrossover(const Individual& a,
                                             const Individual& b, mt19937& rng) {
    int len = (int)a.key.size();
    Individual c1 = a, c2 = b;
    uniform_real_distribution<double> prob(0.0, 1.0);
    if (prob(rng) < 0.7) {
        // Двоточковий кросинговер
        if (len < 2) return {c1, c2};
        uniform_int_distribution<int> d1(0, len - 2);
        int cp1 = d1(rng);
        uniform_int_distribution<int> d2(cp1 + 1, len - 1);
        int cp2 = d2(rng);
        for (int i = cp1; i < cp2; i++) {
            c1.key[i] = b.key[i];
            c2.key[i] = a.key[i];
        }
    } else {
        // Одноточковий кросинговер
        if (len < 2) return {c1, c2};
        uniform_int_distribution<int> d(1, len - 1);
        int cp = d(rng);
        c1.key.clear(); c2.key.clear();
        c1.key.insert(c1.key.end(), a.key.begin(),      a.key.begin() + cp);
        c1.key.insert(c1.key.end(), b.key.begin() + cp, b.key.end());
        c2.key.insert(c2.key.end(), b.key.begin(),      b.key.begin() + cp);
        c2.key.insert(c2.key.end(), a.key.begin() + cp, a.key.end());
    }
    return {c1, c2};
}

// Побайтова мутація з імовірністю rate
void mutate(Individual& ind, double rate, mt19937& rng) {
    uniform_real_distribution<double> prob(0.0, 1.0);
    uniform_int_distribution<int>     rb(0, 255);
    for (auto& b : ind.key)
        if (prob(rng) < rate) b = (uint8_t)rb(rng);
}

// ─── 4. ГОЛОВНА ФУНКЦІЯ ──────────────────────────────────────────

int main(int argc, char* argv[]) {
    string inputFile = "input.txt";
    double w1 = 0.5, w2 = 0.5;
    int    scenario  = 2;
    string csvOut    = "results.csv";

    if (argc >= 2) inputFile = argv[1];
    if (argc >= 3) scenario  = atoi(argv[2]);
    if (argc >= 4) csvOut    = argv[3];

    switch (scenario) {
        case 1:  w1 = 0.7; w2 = 0.3; break; // Сценарій №1: Домінуючий ваговий коефіцієнт ентропії
        case 2:  w1 = 0.5; w2 = 0.5; break; // Сценарій №2: Збалансований розподіл вагових коефіцієнтів
        default: w1 = 0.4; w2 = 0.6; break; // Сценарій №3: Збалансований пріоритет χ²-критерію
    }

    cerr << "======================================\\n";
    cerr << " Криптографiчний аналiзатор v1.0\\n";
    cerr << " Файл:     " << inputFile << "\\n";
    cerr << " Сценарiй: " << scenario
         << "  w1=" << w1 << "  w2=" << w2 << "\\n";
    cerr << " CSV:      " << csvOut << "\\n";
    cerr << "======================================\\n";

    // Зчитування вхідних даних
    vector<uint8_t> data;
    {
        ifstream f(inputFile, ios::binary);
        if (f) data.assign(istreambuf_iterator<char>(f), {});
    }
    if (data.empty()) {
        // Вбудований тестовий рядок (~128 байт, різноманітний ASCII)
        string s = "The quick brown fox jumps over the lazy dog. "
                   "Shannon entropy: H = -sum(p_i * log2(p_i)). "
                   "Genetic algorithm optimization test 0123456789.";
        data.assign(s.begin(), s.end());
        cerr << "Файл не знайдено — використано вбудований тест\\n";
    }

    cerr << "Розмiр вхiдних даних: " << data.size() << " байт\\n";
    if ((int)data.size() < 256)
        cerr << "УВАГА: рекомендується >= 256 байт для уникнення плато ГА\\n";

    // Початкова статистика вхідних даних
    auto freq0 = byteFrequency(data);
    int  n0    = (int)data.size();
    double H0  = calcEntropy(freq0, n0);
    double P0  = pValueFromChi2(chiSquared(freq0, n0));
    cerr << fixed << setprecision(4);
    cerr << "Вихiднi: H0=" << H0 << "  P0=" << P0 << "\\n";

    // Параметри ГА
    const int    popSz   = 200;
    const int    maxGen  = 100;
    const int    keyLen  = 16;
    const double mutRate = 0.05;
    const double target  = 0.80;
    int genToTarget = -1;

    mt19937 rng(42);  // фіксоване зерно для відтворюваності

    auto pop = initPopulation(popSz, keyLen, data, w1, w2, rng);
    sort(pop.begin(), pop.end(),
         [](const Individual& a, const Individual& b){
             return a.fitness > b.fitness;
         });

    // Заголовок CSV
    ofstream csv(csvOut);
    if (!csv) {
        cerr << "Помилка: не вдалося створити файл " << csvOut << "\\n";
        return 1;
    }
    csv  << "Generation;Fitness;Entropy;PValue;ExecutionTime_ms\\n";
    cout << "Generation;Fitness;Entropy;PValue;ExecutionTime_ms\\n";

    // Головний цикл ГА
    for (int gen = 0; gen < maxGen; gen++) {
        // Елітизм: топ-2 особини переходять без змін
        vector<Individual> np = { pop[0], pop[1] };

        while ((int)np.size() < popSz) {
            auto p1 = tournamentSelect(pop, 3, rng);
            auto p2 = tournamentSelect(pop, 3, rng);
            // Гібридний кросинговер: 70% двоточковий, 30% одноточковий
            auto [c1, c2] = hybridCrossover(p1, p2, rng);
            mutate(c1, mutRate, rng);
            c1.fitness = fitnessFunction(data, c1.key, w1, w2);
            mutate(c2, mutRate, rng);
            c2.fitness = fitnessFunction(data, c2.key, w1, w2);
            np.push_back(c1);
            if ((int)np.size() < popSz) np.push_back(c2);
        }

        sort(np.begin(), np.end(),
             [](const Individual& a, const Individual& b){
                 return a.fitness > b.fitness;
             });
        pop = move(np);

        // Статистика найкращої особини покоління
        const auto genStart = std::chrono::high_resolution_clock::now();
        const auto& best = pop[0];
        auto enc = aesCipherExt(data, best.key);
        auto fq  = byteFrequency(enc);
        int  nn  = (int)enc.size();
        double H = calcEntropy(fq, nn);
        double P = pValueFromChi2(chiSquared(fq, nn));
        const auto genEnd  = std::chrono::high_resolution_clock::now();
        const double genMs = std::chrono::duration<double, std::milli>(genEnd - genStart).count();

        // Вивід для CSV (розділювач ; для сумісності з Excel на локалях з комою)
        cout << gen << ";" << fixed << setprecision(6)
             << best.fitness << ";" << H << ";" << P << ";"
             << setprecision(3) << genMs << "\\n";
        csv  << gen << ";" << fixed << setprecision(6)
             << best.fitness << ";" << H << ";" << P << ";"
             << setprecision(3) << genMs << "\\n";

        if (gen % 10 == 0)
            cerr << "Gen " << setw(3) << gen
                 << "  F=" << best.fitness
                 << "  H=" << H << "  P=" << P << "\\n";

        if (genToTarget < 0 && best.fitness >= target)
            genToTarget = gen;
    }

    // Підсумок
    const auto& best = pop[0];
    auto enc = aesCipherExt(data, best.key);
    auto fq  = byteFrequency(enc);
    int  nn  = (int)enc.size();

    cerr << "\\n=== РЕЗУЛЬТАТИ ===\\n";
    cerr << "Ентропiя вихiдних даних:   " << H0 << "\\n";
    cerr << "Ентропiя зашифрованих:     " << calcEntropy(fq, nn) << "\\n";
    cerr << "P-value зашифрованих:      " << pValueFromChi2(chiSquared(fq, nn)) << "\\n";
    cerr << "Найкраще F(X):             " << best.fitness << "\\n";
    if (genToTarget >= 0)
        cerr << "Поколiнь до F(X) >= 0.8: " << genToTarget << "\\n";
    else
        cerr << "Мета F(X) >= 0.8 не досягнута за " << maxGen << " поколiнь\\n";
    cerr << "CSV збережено: " << csvOut << "\\n";

    // ── Автоматичний тест цілісності (Self-Test) ──
    {
        const size_t cmpLen = enc.size();  // повні 16-байтні блоки
        auto dec = aes128Decrypt(enc, best.key);
        // Порівняння відновленого тексту з вихідним масивом data
        bool ok = (dec.size() >= cmpLen) &&
                  equal(data.begin(), data.begin() + (int)min(cmpLen, data.size()),
                        dec.begin());
        cerr << "\\n=== ВЕРИФIКАЦIЯ ДЕШИФРАЦIЇ ===\\n";
        if (ok) {
            cerr << "СТАТУС: OK — 100% цiлiсностi даних пiдтверджено\\n";
            cerr << "Перевiрено байт: " << min(cmpLen, data.size()) << "\\n";
        } else {
            cerr << "СТАТУС: ПОМИЛКА — розбiжностi у вiдновленому текстi!\\n";
        }
    }

    // ── Secure Wipe: гарантоване знулення ключів з пам'яті ──
    // std::fill може бути видалений компілятором як 'dead store' при -O2.
    // volatile-запис унеможливлює цю оптимізацію (захист від cold boot attacks).
    auto secureWipe = [](std::vector<uint8_t>& v) noexcept {
        volatile uint8_t* p = v.data();
        for (size_t i = 0; i < v.size(); ++i) p[i] = 0;
    };
    for (auto& ind : pop) secureWipe(ind.key);  // усі ключі популяції
    secureWipe(enc);                              // зашифровані дані
    cerr << "Secure Wipe: ключi та данi надiйно знулено.\\n";

    return 0;
}`;
