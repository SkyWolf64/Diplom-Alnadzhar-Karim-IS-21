using namespace std;

// ─── 1. СТАТИСТИЧНИЙ АНАЛІЗ ──────────────────────────────────────

// Частотний аналіз байтів вхідного масиву
vector<int> byteFrequency(const vector<uint8_t>& d) {
    vector<int> f(256, 0);
    for (uint8_t b : d) f[b]++;
    return f;
}

// Нормалізована ентропія Шеннона [0..1]
// Максимум для 256 символів = log2(256) = 8 біт  ->  ділимо на 8
double calcEntropy(const vector<int>& freq, int total) {
    if (!total) return 0.0;
    double H = 0.0;
    for (int f : freq)
        if (f > 0) {
            double p = (double)f / total;
            H -= p * log2(p);
        }
    return H / 8.0;
}

// Хі-квадрат тест Пірсона (рівномірність розподілу байтів)
// H0: розподіл рівномірний (256 категорій, очікувана частота = total/256)
double chiSquared(const vector<int>& freq, int total) {
    if (!total) return 0.0;
    double expected = (double)total / 256.0;
    double chi2 = 0.0;
    for (int f : freq) {
        double d = f - expected;
        chi2 += d * d / expected;
    }
    return chi2;
}

// P-value (верхній хвіст): апроксимація Вілсона–Хілферті
// Точність: похибка < 0.001 для chi2 у діапазоні [150, 320] при df=255
double pValueFromChi2(double chi2, int df = 255) {
    if (chi2 <= 0.0) return 0.999;  // ідеально рівномірний розподіл
    double k = (double)df;
    // Нормалізоване відхилення через кубічний корінь
    double z  = pow(chi2 / k, 1.0/3.0) - (1.0 - 2.0/(9.0*k));
    double zs = z / sqrt(2.0 / (9.0*k));
    // CDF нормального розподілу (апроксимація Вілсона–Хілферті)
    double t    = 1.0 / (1.0 + 0.2316419 * fabs(zs));
    double poly = t * (0.31938153
               + t * (-0.356563782
               + t * ( 1.781477937
               + t * (-1.821255978
               + t *   1.330274429))));
    double phi  = 1.0 - (1.0/sqrt(2.0*M_PI)) * exp(-0.5*zs*zs) * poly;
    // Верхній хвіст P(chi2 > observed): 
    //   zs>0 означає chi2 > очікуваного => нерівномірний => мале p
    double pval = (zs >= 0.0) ? (1.0 - phi) : phi;
    // Мінімальне обмеження 0.001 (апроксимація втрачає точність при дуже малих p)
    return max(0.001, min(0.999, pval));
}

