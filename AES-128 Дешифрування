/** Обробляє відкритий файл (.txt/.docx/.pdf та інші текстові) */
async function handleFileOpen(event) {
  const file = event.target.files[0];
  if (!file) return;

  const ext  = file.name.split('.').pop().toLowerCase();
  const info = document.getElementById('dataSizeInfo');
  info.textContent = '⏳ Читання...';
  info.style.color  = 'var(--a2)';

  try {
    let text = '';

    if (ext === 'pdf') {
      // ── PDF через pdf.js ──
      if (typeof pdfjsLib === 'undefined')
        throw new Error('pdf.js не завантажено (потрібен інтернет)');
      pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js';
      const buf = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: buf }).promise;
      for (let p = 1; p <= pdf.numPages; p++) {
        const page    = await pdf.getPage(p);
        const content = await page.getTextContent();
        text += content.items.map(i => i.str).join(' ') + '\n';
      }
      loadFileText(text, file.name, 'PDF');

    } else if (ext === 'docx') {
      // ── Word DOCX через mammoth.js ──
      if (typeof mammoth === 'undefined')
        throw new Error('mammoth.js не завантажено (потрібен інтернет)');
      const buf    = await file.arrayBuffer();
      const result = await mammoth.extractRawText({ arrayBuffer: buf });
      loadFileText(result.value, file.name, 'DOCX');

    } else {
      // ── Будь-який текстовий файл (.txt .csv .md .json тощо) ──
      text = await file.text();
      loadFileText(text, file.name, ext.toUpperCase());
    }
  } catch (err) {
    showMsg(err.message, 'err', 5000);
    info.textContent = '❌ ' + err.message;
    info.style.color  = 'var(--red)';
  }
  event.target.value = ''; // дозволяє відкрити той самий файл знову
}

