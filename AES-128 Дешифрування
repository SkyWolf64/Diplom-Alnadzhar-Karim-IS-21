/** Виконує дешифрацію та відображає результат */
function runDecrypt() {
  // Очищаємо від будь-яких пробілів, переносів, крапок, тире
  let hexCipher = document.getElementById('decCipherHex').value
    .replace(/[\s\r\n\t…\-]/g, '').toUpperCase();
  const hexKey  = document.getElementById('decKeyInput').value
    .replace(/\s/g,'').toUpperCase();
  const statusEl = document.getElementById('decStatus');
  const resultEl = document.getElementById('decResult');
  const outputEl = document.getElementById('decOutputText');

  resultEl.style.display = 'block';

  // Валідація ключа
  if (hexKey.length !== 32 || !/^[0-9A-F]+$/.test(hexKey)) {
    statusEl.innerHTML = '❌ Ключ має бути <b>32 HEX символи</b> (128 біт). Натисніть «Ключ з ГА».';
    statusEl.style.color = 'var(--red)'; outputEl.value = ''; return;
  }
  // Валідація шифротексту
  if (!hexCipher || !/^[0-9A-F]+$/.test(hexCipher)) {
    statusEl.innerHTML = '❌ Шифротекст містить недопустимі символи. Використайте кнопку «⇅ У дешифрацію».';
    statusEl.style.color = 'var(--red)'; outputEl.value = ''; return;
  }
  // Обрізаємо до кратного 32 (повні 16-байтні блоки)
  const fullHexLen = Math.floor(hexCipher.length / 32) * 32;
  if (fullHexLen === 0) {
    statusEl.innerHTML = `❌ Шифротекст занадто короткий (${hexCipher.length} символів). Потрібно мінімум 32 HEX = 1 блок (16 байт).`;
    statusEl.style.color = 'var(--red)'; outputEl.value = ''; return;
  }
  if (hexCipher.length !== fullHexLen) {
    // Автоматично обрізаємо неповний останній блок
    hexCipher = hexCipher.slice(0, fullHexLen);
  }

  // HEX → Uint8Array
  const key = new Uint8Array(16);
  for (let i=0; i<32; i+=2) key[i/2] = parseInt(hexKey.substr(i,2), 16);
  const cipher = new Uint8Array(fullHexLen/2);
  for (let i=0; i<fullHexLen; i+=2) cipher[i/2] = parseInt(hexCipher.substr(i,2), 16);

  // Дешифрація
  const decrypted = aesDecrypt(cipher, key);

  // Декодування UTF-8 або HEX
  let text = '', isText = true;
  try { text = new TextDecoder('utf-8', {fatal: true}).decode(decrypted); }
  catch {
    isText = false;
    text = Array.from(decrypted).map(b => b.toString(16).padStart(2,'0')).join(' ');
  }

  outputEl.value = text;
  const blocks = cipher.length / 16;
  statusEl.innerHTML =
    `<span style="color:var(--grn)">✓ Дешифровано ${cipher.length} байт (${blocks} блок${blocks===1?'':'ів'})</span>` +
    (isText ? ' — UTF-8 текст' : ' — бінарні дані (HEX)');
  statusEl.style.color = '';
}

