/** Апроксимація функції помилок erf */
function erf(x) {
  const sign = x < 0 ? -1 : 1;
  x = Math.abs(x);
  const t  = 1 / (1 + 0.3275911 * x);
  const y  = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t
               - 0.284496736) * t + 0.254829592) * t * Math.exp(-x * x);
  return sign * y;
}

/** NIST Monobit Test: перевірка рівноваги нулів та одиниць у бітовому потоці
 *  Повертає P-value (> 0.01 = пройшов тест)
 */
function monobitTest(data) {
  let sum = 0;
  data.forEach(byte => {
    for (let i = 0; i < 8; i++) {
      sum += ((byte >> i) & 1) ? 1 : -1;
    }
  });
  const sObs   = Math.abs(sum) / Math.sqrt(data.length * 8);
  const pValue = 1 - erf(sObs / Math.sqrt(2));
  return pValue;
}



/** Рахує частоти байтів, показує Top-10 у вказаному елементі */
function updateFrequencyDisplay(data, elementId) {
  const freqs = new Array(256).fill(0);
  const bytes = (typeof data === 'string') ? new TextEncoder().encode(data) : data;
  bytes.forEach(b => freqs[b]++);

  // Сортуємо щоб знайти найбільш вживані (піки)
  const sorted = freqs
    .map((count, byte) => ({ byte, count }))
    .filter(item => item.count > 0)
    .sort((a, b) => b.count - a.count);

  const container = document.getElementById(elementId);
  if (!container) return;
  container.innerHTML = sorted.slice(0, 10).map(item => {
    const label = item.byte === 32 ? 'Space' : String.fromCharCode(item.byte).replace(/[^\x20-\x7E]/g, '·');
    return `<div style="display:flex;justify-content:space-between;border-bottom:1px solid var(--brd);padding:2px 0;font-size:10px">
      <span>[${item.byte}] '<span style="color:#60a5fa">${label}</span>':</span>
      <span style="color:#60a5fa">${item.count}</span>
    </div>`;
  }).join('');

  // Також оновлюємо компактний grid (srcFreq / cipherFreq)
  const gridId = elementId === 'sourceFreqList' ? 'srcFreq' : elementId === 'cipherFreqList' ? 'cipherFreq' : null;
  if (gridId) {
    const gridEl = document.getElementById(gridId);
    if (gridEl) {
      gridEl.innerHTML = sorted.slice(0, 10).map(item => {
        const label = item.byte === 32 ? 'Spc' : String.fromCharCode(item.byte).replace(/[^\x20-\x7E]/g, '·');
        return `<span style="color:var(--mut)">[${item.byte}]</span><span style="color:#60a5fa"> ${item.count}</span>  `;
      }).join('');
    }
  }
}

/** Завантажує CSV частот відкритого тексту (формат для NIST аналізу) */
function dlSourceCSV() {
  const text = document.getElementById('txt').value;  // правильний ID textarea
  if (!text) { showMsg('Введіть або вставте текст у поле вхідних даних (мінімум 16 байт).'); return; }
  const freqs = new Array(256).fill(0);
  const bytes = new TextEncoder().encode(text);
  bytes.forEach(b => freqs[b]++);

  // Формат як на скріншоті: Byte;Frequency
  let csv = 'Byte;Frequency\n' + freqs.map((f, i) => `${i};${f}`).join('\n');

  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = 'source_freq.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 150);
}

/** Тест чутливості ключа AES-128 (лавинний ефект по позиціях байтів) */
function testAvalanche() {
  const data = toBytes(document.getElementById('txt').value);
  if (data.length < 16) {
    showMsg('Для тесту лавинного ефекту потрібно мінімум 16 байт тексту.', 'warn');
    return;
  }
  // Беремо ключ з поля або генеруємо
  let hexIn = document.getElementById('manualKeyInput').value.replace(/\s/g, '');
  if (hexIn.length !== 32 || !/^[0-9a-fA-F]+$/.test(hexIn)) {
    const b = new Uint8Array(16);
    crypto.getRandomValues(b);
    hexIn = Array.from(b).map(x => x.toString(16).padStart(2,'0')).join('');
    document.getElementById('manualKeyInput').value = hexIn;
  }
  const key1 = new Uint8Array(16);
  for (let i = 0; i < 32; i += 2) key1[i/2] = parseInt(hexIn.substr(i, 2), 16);

  const enc1 = aesCipher(data, key1);

  // Для кожного байту ключа: змінюємо 1 біт і рахуємо кількість змінених бітів
  // у відповідній позиції виходу (байт-паралельна архітектура SubBytes+AddRoundKey)
  let totalDiffBits = 0;
  const blockCount = Math.floor(data.length / 16);
  const testedBytes = blockCount * 16; // повні блоки

  for (let byteIdx = 0; byteIdx < 16; byteIdx++) {
    const key2 = new Uint8Array(key1);
    key2[byteIdx] ^= 0x01; // 1-бітна зміна у ключі
    const enc2 = aesCipher(data, key2);
    // Рахуємо різницю лише у позиціях byteIdx у кожному блоці
    for (let blk = 0; blk < blockCount; blk++) {
      let xor = enc1[blk * 16 + byteIdx] ^ enc2[blk * 16 + byteIdx];
      while (xor) { totalDiffBits += xor & 1; xor >>= 1; }
    }
  }

  const totalBits = blockCount * 16 * 8; // 16 байт × 8 біт × blockCount
  const diffPct   = ((totalDiffBits / totalBits) * 100).toFixed(1);
  const hex1short = Array.from(enc1.slice(0, 8)).map(b => b.toString(16).padStart(2,'0')).join('');
  const isGood    = parseFloat(diffPct) >= 40;

  log('─'.repeat(50), '#2d3f6e');
  log('⚡ ТЕСТ ЧУТЛИВОСТІ КЛЮЧА AES-128', '#f59e0b');
  log(`Ключ: ${hexIn.toUpperCase().slice(0, 16)}...  блоків: ${blockCount}`, '#06b6d4');
  log(`Шифротекст (перші 8 байт): ${hex1short.toUpperCase()}`, '#e2e8f0');
  log(`Для кожного з 16 байт ключа: змінено 1 біт → вимірюємо зміну виходу`, '#e2e8f0');
  log(`Відмінних бітів у виході: ${totalDiffBits}/${totalBits} (${diffPct}%) — ідеал ~50%`,
      isGood ? '#22d3ee' : '#f59e0b');
  log(isGood ? '✓ Ключ має хорошу чутливість по всіх позиціях'
              : '⚠ Чутливість нижче очікуваної (~50%)',
      isGood ? '#22d3ee' : '#f59e0b');
  log('─'.repeat(50), '#2d3f6e');

  sw('a');
}



