function gmul9 (x) { return (xtime(xtime(xtime(x))) ^ x) & 0xff; }
function gmul11(x) { return (xtime(xtime(xtime(x))) ^ xtime(x) ^ x) & 0xff; }
function gmul13(x) { return (xtime(xtime(xtime(x))) ^ xtime(xtime(x)) ^ x) & 0xff; }
function gmul14(x) { return (xtime(xtime(xtime(x))) ^ xtime(xtime(x)) ^ xtime(x)) & 0xff; }

function invSubBytes(s)  { for (let i=0;i<16;i++) s[i]=AES_INV_SBOX[s[i]]; }
function invShiftRows(s) {
  let t;
  t=s[13]; s[13]=s[9]; s[9]=s[5]; s[5]=s[1]; s[1]=t;
  t=s[2];  s[2]=s[10]; s[10]=t; t=s[6]; s[6]=s[14]; s[14]=t;
  t=s[3];  s[3]=s[7];  s[7]=s[11]; s[11]=s[15]; s[15]=t;
}
function invMixColumns(s) {
  for (let c=0;c<4;c++) {
    const s0=s[c*4],s1=s[c*4+1],s2=s[c*4+2],s3=s[c*4+3];
    s[c*4]  = gmul14(s0)^gmul11(s1)^gmul13(s2)^gmul9(s3);
    s[c*4+1]= gmul9(s0) ^gmul14(s1)^gmul11(s2)^gmul13(s3);
    s[c*4+2]= gmul13(s0)^gmul9(s1) ^gmul14(s2)^gmul11(s3);
    s[c*4+3]= gmul11(s0)^gmul13(s1)^gmul9(s2) ^gmul14(s3);
  }
}

/** Дешифрування одного 128-бітного блоку (FIPS 197 §5.3) */
function aesDecryptBlock(block, key) {
  const w = aesKeyExpansion(key);
  for (let i=0;i<16;i++) block[i] ^= w[10][i];
  for (let r=9;r>=1;r--) {
    invShiftRows(block); invSubBytes(block);
    for (let i=0;i<16;i++) block[i] ^= w[r][i];
    invMixColumns(block);
  }
  invShiftRows(block); invSubBytes(block);
  for (let i=0;i<16;i++) block[i] ^= w[0][i];
}

/** Дешифрування потоку даних блоками 128 біт (ECB mode) */
function aesDecrypt(cipherData, key) {
  const result = new Uint8Array(cipherData);
  for (let i=0; i+15 < result.length; i+=16)
    aesDecryptBlock(result.subarray(i,i+16), key);
  return result;
}

