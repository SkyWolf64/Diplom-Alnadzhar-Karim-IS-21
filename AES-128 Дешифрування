/** Аналізує HEX-ключ введений вручну */
function runManualVerify() {
  const raw = document.getElementById('manualKeyInput').value.replace(/\s/g, '');
  const res = document.getElementById('manualVerifyResult');
  if (raw.length !== 32 || !/^[0-9a-fA-F]+$/.test(raw)) {
    res.textContent = '❌ Ключ має бути рівно 32 HEX-символи (16 байт). Приклад: 2b7e151628aed2a6abf7158809cf4f3c';
    res.style.color = '#ef4444';
    return;
  }
  // Перетворення HEX → Uint8Array
  const key = new Uint8Array(16);
  for (let i = 0; i < 32; i += 2)
    key[i/2] = parseInt(raw.substr(i, 2), 16);

  const data = toBytes(document.getElementById('txt').value);
  if (data.length < 16) {
    res.textContent = '❌ Потрібно мінімум 16 байт у полі введення.';
    res.style.color = '#ef4444';
    return;
  }
  const enc  = aesCipher(data, key);
  const freq = byteFrequency(enc);
  const n    = enc.length;
  const H    = calcEntropy(freq, n);
  const P    = pValueFromChi2(chiSquared(freq, n));
  const F    = W1 * H + W2 * P;

  res.innerHTML =
    `<span style="color:var(--acc)">F(X)=${F.toFixed(4)}</span> &nbsp;` +
    `<span style="color:var(--grn)">H=${H.toFixed(4)}</span> &nbsp;` +
    `<span style="color:var(--org)">P=${P.toFixed(4)}</span> &nbsp;` +
    `<span style="color:var(--mut);font-size:9px">ключ: ${raw.toUpperCase()}</span>`;
  res.style.color = '';

  // Оновити індикатор складності
  updateKeyStrength(F);

  // Частотний аналіз — відкритий текст і шифротекст
  updateFrequencyDisplay(data, 'sourceFreqList');
  updateFrequencyDisplay(enc,  'cipherFreqList');

  // Зберігаємо повний шифротекст глобально для дешифрації
  lastEncryptedHex = Array.from(enc).map(b => b.toString(16).padStart(2,'0')).join('');

  // Ciphertext Preview — перші 64 байти у HEX
  const previewWrap = document.getElementById('ciphertextPreviewWrap');
  const previewEl   = document.getElementById('ciphertextPreview');
  const previewBytes = Array.from(enc.slice(0, 64))
    .map(b => b.toString(16).padStart(2,'0'));
  // Групуємо по 8 байт
  let html = '';
  for (let i = 0; i < previewBytes.length; i++) {
    if (i > 0 && i % 8 === 0) html += ' ';
    html += previewBytes[i];
  }
  previewEl.textContent = html + (enc.length > 64 ? ' …' : '');
  previewWrap.style.display = 'block';

  // Оновити частотний аналіз для шифротексту
  updateFrequencyDisplay(data, 'sourceFreqList');
  updateFrequencyDisplay(enc, 'cipherFreqList');

  // Оновити метрики на екрані
  updateMetrics(F, H, P);
}

/** Очищає поле вводу тексту */
function clearText() {
  document.getElementById('txt').value = '';
  checkDataSize();

  // Гістограма частот (Chart.js)
  updateCharts('', [], []);

  // Поточні метрики → скидаємо до нулів
  ['mF','mH','mP'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.textContent = '0.000'; el.style.color = 'var(--mut)'; }
  });
  ['bF','bH','bP'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.style.width = '0%'; el.style.background = 'var(--mut)'; }
  });

  // Графік збіжності cv (canvas)
  drawChart([], [], [], 0.9);

  // Частотний аналіз (Top-10 списки)
  ['sourceFreqList','cipherFreqList'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = '<div style="color:var(--mut);font-size:9px;padding:4px 0">— немає даних —</div>';
  });
  // Також очищаємо srcFreq / cipherFreq гриди якщо є
  ['srcFreq','cipherFreq'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = '';
  });

  // Лог виконання
  clearLog();

  // Статус
  setStatus('', '');

  // lastEncryptedHex
  lastEncryptedHex = '';

  // Дані CSV для Excel
  const csvPr = document.getElementById('csvPr');
  if (csvPr) csvPr.textContent = '— запустіть аналіз для отримання даних —';
}

/** Генерує випадковий 128-бітний AES-ключ у HEX */
function genRandomKey() {
  const bytes = new Uint8Array(16);
  crypto.getRandomValues(bytes);
  const hex = Array.from(bytes).map(b => b.toString(16).padStart(2,'0')).join('');
  document.getElementById('manualKeyInput').value = hex;
  document.getElementById('manualVerifyResult').textContent =
    'Випадковий ключ згенеровано. Натисніть «Аналізувати» для оцінки.';
  // Скидаємо застарілі дані
  document.getElementById('keyStrengthBar').style.width = '0%';
  document.getElementById('keyStrengthBar').style.background = 'var(--red)';
  document.getElementById('keyStrengthLabel').textContent = '—';
  document.getElementById('keyStrengthLabel').style.color = 'var(--mut)';
  document.getElementById('ciphertextPreviewWrap').style.display = 'none';
}

/** Копіює поточний HEX-ключ з поля в буфер обміну */
function copyKeyClipboard() {
  const hex = document.getElementById('manualKeyInput').value.trim();
  if (!hex) { showMsg('Введіть ключ (32 HEX символи = 128 біт) або натисніть «🎲 Випадковий ключ».', 'warn'); return; }
  if (navigator.clipboard) {
    navigator.clipboard.writeText(hex).then(() => {
      const btn = document.getElementById('btnCopyKeyClip');
      const orig = btn.innerHTML;
      btn.innerHTML = '✓ Скопійовано';
      setTimeout(() => { btn.innerHTML = orig; }, 1500);
    });
  } else {
    const ta = document.createElement('textarea');
    ta.value = hex; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
  }
}

/** Оновлює індикатор складності ключа */
function updateKeyStrength(F) {
  const bar   = document.getElementById('keyStrengthBar');
  const label = document.getElementById('keyStrengthLabel');
  const pct   = Math.round(F * 100);
  bar.style.width = pct + '%';
  if (F >= 0.85) {
    bar.style.background = 'var(--grn)';
    label.textContent = pct + '% — Сильний ключ ✓';
    label.style.color = 'var(--grn)';
  } else if (F >= 0.6) {
    bar.style.background = 'var(--org)';
    label.textContent = pct + '% — Середній ключ';
    label.style.color = 'var(--org)';
  } else {
    bar.style.background = 'var(--red)';
    label.textContent = pct + '% — Слабкий ключ ✗';
    label.style.color = 'var(--red)';
  }
}


