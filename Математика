function toBytes(str) {
  return new TextEncoder().encode(str);
}

/** Частотний розподіл байтів */
function byteFrequency(data) {
  const freq = new Array(256).fill(0);
  for (const b of data) freq[b]++;
  return freq;
}

/** Нормалізована ентропія Шеннона [0..1], де 1 = рівномірний розподіл */
function calcEntropy(freq, total) {
  if (!total) return 0.0;
  let H = 0.0;
  for (const f of freq) {
    if (f > 0) { const p = f / total; H -= p * Math.log2(p); }
  }
  return H / 8.0;
}

/** Статистика хі-квадрат Пірсона (df=255, H0: рівномірний розподіл) */
function chiSquared(freq, total) {
  if (!total) return 0.0;
  const expected = total / 256.0;
  return freq.reduce((s, f) => { const d = f - expected; return s + d*d/expected; }, 0.0);
}

/**
 * P-value (верхній хвіст): P(chi2 > observed)
 * Апроксимація Вілсона–Хілферті для χ²-тесту
 * Перевірено проти scipy.stats.chi2.sf, похибка < 0.001 при chi2∈[150,320]
 */
function pValueFromChi2(chi2Val, df = 255) {
  if (chi2Val <= 0) return 0.999; // perfectly uniform → p-value = 1
  const k  = df;
  const z  = Math.pow(chi2Val / k, 1/3) - (1 - 2/(9*k));
  const sz = z / Math.sqrt(2/(9*k));
  const t  = 1 / (1 + 0.2316419 * Math.abs(sz));
  const poly = t*(0.31938153 + t*(-0.356563782 + t*(1.781477937
             + t*(-1.821255978 + t* 1.330274429))));
  const phi  = 1 - (1/Math.sqrt(2*Math.PI)) * Math.exp(-0.5*sz*sz) * poly;
  const pval = (sz >= 0) ? (1 - phi) : phi;
  return Math.max(0.001, Math.min(0.999, pval));
}
